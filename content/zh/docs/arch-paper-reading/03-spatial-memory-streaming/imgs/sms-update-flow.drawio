        </mxCell>
        <mxCell id="su_second" parent="su_live_group" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fontStyle=1;align=center;fillColor=#dcfce7;strokeColor=#16a34a;strokeWidth=2;" value="second distinct block&#xa;promote to accumulation" vertex="1">
          <mxGeometry height="120" width="280" x="410" y="120" as="geometry" />
        </mxCell>
        <mxCell id="su_accum" parent="su_live_group" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fontStyle=1;align=center;fillColor=#ffedd5;strokeColor=#c2410c;strokeWidth=2;" value="accumulate bits&#xa;set one bit per new block" vertex="1">
          <mxGeometry height="120" width="320" x="790" y="180" as="geometry" />
