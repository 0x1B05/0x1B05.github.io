          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge_4" edge="1" parent="su_live_group" source="su_end" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endSize=8;strokeColor=#64748b;strokeWidth=4;jumpStyle=arc;exitX=1.0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.0;entryY=0.5;entryDx=0;entryDy=0;dashed=1;fontSize=20;dashPattern=12 8;" target="su_commit" value="mature mask">
