        <mxCell id="su_end" parent="su_live_group" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fontStyle=1;align=center;fillColor=#fee2e2;strokeColor=#ef4444;strokeWidth=2;" value="generation end&#xa;eviction / invalidation" vertex="1">
          <mxGeometry height="100" width="260" x="1240" y="110" as="geometry" />
