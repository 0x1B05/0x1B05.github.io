        <mxCell id="su_drop" parent="su_live_group" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fontStyle=1;align=center;fillColor=#fce7f3;strokeColor=#be185d;strokeWidth=2;" value="drop&#xa;filter-only case" vertex="1">
          <mxGeometry height="110" width="220" x="1620" y="60" as="geometry" />
        </mxCell>
        <mxCell id="su_commit" parent="su_live_group" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fontStyle=1;align=center;fillColor=#ede9fe;strokeColor=#7c3aed;strokeWidth=2;" value="commit mask&#xa;write PHT entry" vertex="1">
          <mxGeometry height="110" width="220" x="1620" y="210" as="geometry" />
        </mxCell>
        <mxCell id="edge_0" edge="1" parent="su_live_group" source="su_trigger" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endSize=8;strokeColor=#2563eb;strokeWidth=4;jumpStyle=arc;exitX=1.0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.0;entryY=0.5;entryDx=0;entryDy=0;fontSize=20;" target="su_second" value="same generation">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge_1" edge="1" parent="su_live_group" source="su_second" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endSize=8;strokeColor=#2563eb;strokeWidth=4;jumpStyle=arc;exitX=1.0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.0;entryY=0.5;entryDx=0;entryDy=0;fontSize=20;" target="su_accum" value="promotion">
          <mxGeometry relative="1" as="geometry" />
